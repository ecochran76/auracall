{
  "$schema": "https://biomejs.dev/schemas/2.3.11/schema.json",
  "javascript": {
    "globals": ["Bun"]
  },
  "formatter": {
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": {
          "level": "error",
          "options": {
            "ignoreRestSiblings": false
          }
        },
        "noUnusedImports": "error",
        "noUndeclaredVariables": {
          "level": "error",
          "options": {
            "checkTypes": true
          }
        }
      },
      "complexity": {
        "noUselessFragments": "warn",
        "noUselessLoneBlockStatements": "warn"
      },
      "style": {
        "useConsistentObjectDefinitions": {
          "level": "warn",
          "options": {
            "syntax": "shorthand"
          }
        },
        "useNamingConvention": {
          "level": "warn",
          "options": {
            "strictCase": false,
            "conventions": [
              {
                "selector": {
                  "kind": "typeLike"
                },
                "formats": [
                  "PascalCase"
                ]
              },
              {
                "selector": {
                  "kind": "function"
                },
                "formats": [
                  "camelCase",
                  "PascalCase"
                ]
              },
              {
                "selector": {
                  "kind": "variable"
                },
                "formats": [
                  "camelCase",
                  "CONSTANT_CASE"
                ]
              },
              {
                "selector": {
                  "kind": "classMember"
                },
                "formats": [
                  "camelCase",
                  "CONSTANT_CASE"
                ]
              },
              {
                "selector": {
                  "kind": "typeMember"
                },
                "formats": [
                  "camelCase",
                  "snake_case"
                ]
              },
              {
                "selector": {
                  "kind": "objectLiteralMember"
                },
                "formats": [
                  "camelCase",
                  "snake_case"
                ]
              }
            ]
          }
        }
      },
      "security": {
        "noGlobalEval": "error"
      },
      "nursery": {
        "noFloatingPromises": "error",
        "noUnnecessaryConditions": "warn"
      }
    }
  },
  "files": {
    "includes": [
      "src/**/*.{js,ts}",
      "bin/**/*.js",
      "scripts/**/*.{js,ts}",
      "!scripts/browser-tools.ts",
      "tests/**/*.ts",
      "!node_modules/**/*",
      "!coverage/**/*",
      "!.bun-check/**/*"
    ]
  },
  "overrides": [
    {
      "includes": [
        "src/teams/schema.ts",
        "src/runtime/schema.ts",
        "src/runtime/apiSchema.ts",
        "src/media/schema.ts",
        "src/workbench/schema.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "useNamingConvention": "off"
          }
        }
      }
    },
    {
      "includes": [
        "scripts/chatgpt-acceptance.ts",
        "scripts/grok-acceptance.ts",
        "scripts/smoke-api-status-mcp.ts",
        "scripts/verify-cache-refresh-modes.ts",
        "tests/live/liveConversationCleanup.ts",
        "tests/live/team-chatgpt-live.test.ts",
        "tests/live/team-gemini-live.test.ts",
        "tests/live/team-multiservice-live.test.ts",
        "tests/cli/cacheGeminiParity.test.ts",
        "tests/http.responsesServer.test.ts",
        "tests/mediaBrowserDiagnostics.test.ts",
        "tests/mcp.integration.test.ts",
        "tests/mcp.resources.test.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "useNamingConvention": "off"
          }
        }
      }
    },
    {
      "includes": [
        "src/browser/actions/grok.ts",
        "src/browser/actions/navigation.ts",
        "src/browser/index.ts",
        "src/browser/llmService/cache/catalog.ts",
        "src/browser/llmService/cache/export.ts",
        "src/browser/llmService/cache/search.ts",
        "src/browser/providers/chatgptAdapter.ts",
        "src/browser/providers/geminiAdapter.ts",
        "src/browser/providers/grokAdapter.ts",
        "src/browser/providers/mutationAudit.ts",
        "src/browser/reattachCore.ts",
        "src/gemini-web/browserNative.ts",
        "src/runtime/stepOutputContract.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "useNamingConvention": "off"
          }
        }
      }
    }
  ]
}
